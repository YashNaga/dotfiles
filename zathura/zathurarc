set selection-clipboard clipboard
set synctex true
set font 'monocraft 14'

map U scroll half-up
map D scroll halp-down
map K zoom in
map J zoom out
map r reload
map R rotate
map p print
map i recolor

set guioptions "sv"
set scroll-page-aware "true"
set statusbar-home-tilde "true"
set recolor "true"

set statusbar-h-padding 10
set statusbar-v-padding 10

set recolor "true"
set recolor-keephue "true"

include kanagawa

